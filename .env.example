# Vacaville Plumbing — Environment Variables
# Copy this file to .env and fill in the values

# Site URL (update after Netlify deploy)
# PUBLIC_SITE_URL=https://www.vacavilleplumbing.com

# Contact form endpoint (optional — for future form backend integration)
# PUBLIC_FORM_ENDPOINT=

# Google Maps Embed Key (optional — for service area map)
# PUBLIC_GOOGLE_MAPS_KEY=
