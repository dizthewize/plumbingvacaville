---
interface Props {
  formTitle?: string;
  submitLabel?: string;
  compact?: boolean;
  id?: string;
}

const {
  formTitle = 'Get Your Free Estimate',
  submitLabel = 'Request My Free Estimate',
  compact = false,
  id = 'lead-form',
} = Astro.props;

const serviceOptions = [
  'Drain Cleaning',
  'Water Heater Repair',
  'Leak Detection',
  'Emergency Plumbing',
  'Repiping',
  'Bathroom & Kitchen Plumbing',
  'Fixture Installation',
  'Sewer Line',
  'Other',
];
---

<div class={`lead-form-wrap ${compact ? 'lead-form-wrap--compact' : ''}`} id={id}>
  <h3 class="lead-form__title">{formTitle}</h3>

  <form class="lead-form" id={`${id}-form`} novalidate>
    <!-- Honeypot (spam protection) -->
    <input
      type="text"
      name="_honey"
      class="lead-form__honeypot"
      tabindex="-1"
      autocomplete="off"
      aria-hidden="true"
    />

    <div class="lead-form__field">
      <label for={`${id}-name`} class="lead-form__label">
        Full Name <span class="lead-form__required" aria-hidden="true">*</span>
      </label>
      <input
        type="text"
        id={`${id}-name`}
        name="name"
        class="lead-form__input"
        autocomplete="name"
        aria-required="true"
        placeholder="Jane Smith"
      />
      <span class="lead-form__error" id={`${id}-name-error`} role="alert" aria-live="polite"></span>
    </div>

    <div class="lead-form__field">
      <label for={`${id}-phone`} class="lead-form__label">
        Phone Number <span class="lead-form__required" aria-hidden="true">*</span>
      </label>
      <input
        type="tel"
        id={`${id}-phone`}
        name="phone"
        class="lead-form__input"
        autocomplete="tel"
        inputmode="numeric"
        aria-required="true"
        placeholder="(916) 555-1234"
      />
      <span class="lead-form__error" id={`${id}-phone-error`} role="alert" aria-live="polite"></span>
    </div>

    <div class="lead-form__field">
      <label for={`${id}-email`} class="lead-form__label">
        Email Address <span class="lead-form__required" aria-hidden="true">*</span>
      </label>
      <input
        type="email"
        id={`${id}-email`}
        name="email"
        class="lead-form__input"
        autocomplete="email"
        aria-required="true"
        placeholder="jane@example.com"
      />
      <span class="lead-form__error" id={`${id}-email-error`} role="alert" aria-live="polite"></span>
    </div>

    <div class="lead-form__field">
      <label for={`${id}-service`} class="lead-form__label">
        Service Needed
      </label>
      <select
        id={`${id}-service`}
        name="service"
        class="lead-form__select"
        autocomplete="off"
      >
        <option value="">Select a service...</option>
        {serviceOptions.map((opt) => (
          <option value={opt.toLowerCase().replace(/[^a-z0-9]+/g, '-')}>{opt}</option>
        ))}
      </select>
    </div>

    <button
      type="submit"
      class="lead-form__submit"
      id={`${id}-submit`}
    >
      <span class="lead-form__submit-text">{submitLabel}</span>
      <span class="lead-form__submit-loading sr-only" aria-live="polite">Submitting...</span>
    </button>

    <p class="lead-form__microcopy">
      No spam. We respond same day.
    </p>
  </form>

  <!-- Success state (hidden until submit) -->
  <div class="lead-form__success" id={`${id}-success`} aria-live="polite" hidden>
    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lead-form__success-icon" aria-hidden="true">
      <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
      <polyline points="22 4 12 14.01 9 11.01"/>
    </svg>
    <p class="lead-form__success-text">
      Thanks! We'll call you within 24 hours.
    </p>
  </div>
</div>

<script>
  document.querySelectorAll('.lead-form').forEach((formEl) => {
    const form = formEl as HTMLFormElement;
    const formId = form.id.replace('-form', '');
    const submitBtn = document.getElementById(`${formId}-submit`) as HTMLButtonElement;
    const successDiv = document.getElementById(`${formId}-success`);

    function getField(name: string) {
      return form.querySelector(`[name="${name}"]`) as HTMLInputElement | null;
    }

    function showError(fieldName: string, message: string) {
      const field = getField(fieldName);
      const errorEl = document.getElementById(`${formId}-${fieldName}-error`);
      if (field) {
        field.classList.add('lead-form__input--error');
        field.setAttribute('aria-describedby', `${formId}-${fieldName}-error`);
      }
      if (errorEl) errorEl.textContent = message;
    }

    function clearErrors() {
      form.querySelectorAll('.lead-form__input--error').forEach((el) => {
        el.classList.remove('lead-form__input--error');
        el.removeAttribute('aria-describedby');
      });
      form.querySelectorAll('.lead-form__error').forEach((el) => {
        (el as HTMLElement).textContent = '';
      });
    }

    function validate(): boolean {
      clearErrors();
      let valid = true;
      const name = getField('name');
      const phone = getField('phone');
      const email = getField('email');

      if (!name?.value.trim()) {
        showError('name', 'Please enter your full name.');
        valid = false;
      }
      if (!phone?.value.trim()) {
        showError('phone', 'Please enter a valid phone number.');
        valid = false;
      }
      if (!email?.value.trim() || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)) {
        showError('email', 'Please enter a valid email address.');
        valid = false;
      }

      // Focus first invalid field
      if (!valid) {
        const firstError = form.querySelector('.lead-form__input--error') as HTMLElement;
        firstError?.focus();
      }

      return valid;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Honeypot check
      const honey = form.querySelector('[name="_honey"]') as HTMLInputElement;
      if (honey?.value) return;

      if (!validate()) return;

      // Disable button + show loading
      submitBtn.disabled = true;
      submitBtn.querySelector('.lead-form__submit-text')?.classList.add('sr-only');
      submitBtn.querySelector('.lead-form__submit-loading')?.classList.remove('sr-only');

      // Simulate submission (replace with real endpoint when available)
      await new Promise((res) => setTimeout(res, 800));

      // Show success
      form.hidden = true;
      if (successDiv) successDiv.hidden = false;
    });

    // Validate on blur
    form.querySelectorAll('.lead-form__input').forEach((input) => {
      input.addEventListener('blur', () => {
        const name = (input as HTMLInputElement).name;
        if (['name', 'phone', 'email'].includes(name)) {
          validate();
        }
      });
    });
  });
</script>

<style>
  .lead-form-wrap {
    background: var(--color-bg);
    border-radius: 6px;
    padding: 32px;
  }

  .lead-form-wrap--compact {
    padding: 24px;
  }

  .lead-form__title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: var(--space-3);
    line-height: 1.3;
  }

  .lead-form__field {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: var(--space-2);
  }

  .lead-form__label {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .lead-form__required {
    color: var(--color-error);
    margin-left: 2px;
  }

  .lead-form__input,
  .lead-form__select {
    height: 44px;
    padding: 0 14px;
    border: 1.5px solid var(--color-neutral-200);
    border-radius: 4px;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
    background: var(--color-bg);
    transition: border-color 150ms ease, box-shadow 150ms ease;
    width: 100%;
    appearance: auto;
  }

  .lead-form__input:focus,
  .lead-form__select:focus {
    outline: none;
    border-color: var(--color-primary-light);
    box-shadow: 0 0 0 3px rgba(41, 128, 185, 0.15);
  }

  .lead-form__input--error {
    border-color: var(--color-error) !important;
  }

  .lead-form__error {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-error);
    min-height: 1.2em;
  }

  .lead-form__honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  .lead-form__submit {
    width: 100%;
    height: 52px;
    background: var(--color-accent);
    color: #ffffff;
    border: none;
    border-radius: 4px;
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    cursor: pointer;
    margin-top: var(--space-1);
    transition: background 150ms ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lead-form__submit:hover {
    background: var(--color-accent-dark);
  }

  .lead-form__submit:disabled {
    background: var(--color-neutral-200);
    color: var(--color-text-muted);
    cursor: not-allowed;
  }

  .lead-form__microcopy {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-align: center;
    margin-top: var(--space-1);
    max-width: none;
  }

  /* Success state */
  .lead-form__success {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-6) var(--space-3);
    text-align: center;
  }

  .lead-form__success-icon {
    color: #16a34a;
    width: 48px;
    height: 48px;
  }

  .lead-form__success-text {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-primary);
    max-width: none;
  }
</style>
