---
interface Service {
  name: string;
  slug: string;
  benefit: string;
  icon: string;
}

interface Props {
  services?: Service[];
  headline?: string;
  subheadline?: string;
}

const defaultServices: Service[] = [
  { name: 'Drain Cleaning & Unclogging', slug: 'drain-cleaning', benefit: 'Same-day clearing for slow or fully blocked drains.', icon: 'droplets' },
  { name: 'Water Heater Repair & Installation', slug: 'water-heater', benefit: 'All makes and models — tank and tankless.', icon: 'flame' },
  { name: 'Leak Detection & Repair', slug: 'leak-detection', benefit: 'Find hidden leaks fast — before they cause damage.', icon: 'search' },
  { name: 'Pipe Replacement & Repiping', slug: 'repiping', benefit: 'Full and partial repipes with copper or PEX.', icon: 'git-branch' },
  { name: 'Emergency Plumbing', slug: 'emergency-plumbing', benefit: '24/7 response. A real plumber answers every call.', icon: 'alert-triangle' },
  { name: 'Bathroom & Kitchen Plumbing', slug: 'bathroom-kitchen-plumbing', benefit: 'Remodels, rough-in, fixture installs — done right.', icon: 'hammer' },
  { name: 'Toilet, Faucet & Fixture Installation', slug: 'fixture-installation', benefit: 'Clean installs with an upfront price before we start.', icon: 'wrench' },
  { name: 'Sewer Line Inspection & Repair', slug: 'sewer-line', benefit: 'Camera inspection, root removal, trenchless options.', icon: 'waves' },
];

const {
  services = defaultServices,
  headline = 'Plumbing Services in Vacaville',
  subheadline = 'Licensed, insured, and upfront on every job.',
} = Astro.props;

// SVG icon paths
const iconPaths: Record<string, string> = {
  droplets: '<path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/><path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97"/>',
  flame: '<path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>',
  search: '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>',
  'git-branch': '<line x1="6" x2="6" y1="3" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/>',
  'alert-triangle': '<path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/>',
  hammer: '<path d="m15 12-8.5 8.5c-.83.83-2.17.83-3 0 0 0 0 0 0 0a2.12 2.12 0 0 1 0-3L12 9"/><path d="M17.64 15 22 10.64"/><path d="m20.91 11.7-1.25-1.25c-.6-.6-.93-1.4-.93-2.25v-.86L16.01 4.6a5.56 5.56 0 0 0-3.94-1.64H9l.92.82A6.18 6.18 0 0 1 12 8.4v1.56l2 2h2.47l2.26 1.91"/>',
  wrench: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
  waves: '<path d="M2 6c.6.5 1.2 1 2.5 1C7 7 7 5 9.5 5c2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/>',
};
---

<section class="services-grid" aria-labelledby="services-heading">
  <div class="container">
    <div class="services-grid__header">
      <h2 id="services-heading" class="services-grid__headline">{headline}</h2>
      <p class="services-grid__subheadline">{subheadline}</p>
    </div>

    <div class="services-grid__grid">
      {services.map((service) => (
        <article class="services-grid__card">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="40"
            height="40"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="services-grid__icon"
            aria-hidden="true"
            set:html={iconPaths[service.icon] ?? iconPaths.wrench}
          />
          <h3 class="services-grid__service-name">{service.name}</h3>
          <p class="services-grid__benefit">{service.benefit}</p>
          <a
            href={`/services/${service.slug}`}
            class="services-grid__link"
            aria-label={`Learn about ${service.name}`}
          >
            Learn about {service.name}
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services-grid {
    background: var(--color-bg-section);
    padding: var(--space-12) 0;
  }

  .services-grid__header {
    text-align: center;
    margin-bottom: var(--space-6);
  }

  .services-grid__headline {
    color: var(--color-primary);
    margin-bottom: var(--space-1);
  }

  .services-grid__subheadline {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: var(--color-text-muted);
    max-width: 560px;
    margin-inline: auto;
  }

  .services-grid__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
  }

  @media (min-width: 640px) {
    .services-grid__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .services-grid__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .services-grid__card {
    background: var(--color-bg);
    border: 1px solid var(--color-neutral-200);
    border-left: 3px solid transparent;
    border-radius: 6px;
    padding: 28px 24px;
    transition: border-left-color 200ms ease, box-shadow 200ms ease;
  }

  @media (prefers-reduced-motion: no-preference) {
    .services-grid__card {
      transition: border-left-color 200ms ease, box-shadow 200ms ease, transform 200ms ease;
    }

    .services-grid__card:hover {
      transform: translateY(-2px);
    }
  }

  .services-grid__card:hover {
    border-left-color: var(--color-accent);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .services-grid__icon {
    color: var(--color-accent);
    display: block;
  }

  .services-grid__service-name {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-top: 12px;
    margin-bottom: 6px;
  }

  .services-grid__benefit {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin-bottom: var(--space-2);
    max-width: none;
  }

  .services-grid__link {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-primary-light);
    text-decoration: underline;
    display: block;
    margin-top: var(--space-2);
    transition: color 150ms ease;
  }

  .services-grid__link:hover {
    color: var(--color-primary);
  }
</style>
