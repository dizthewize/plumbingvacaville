---
interface Cta {
  label: string;
  href: string;
}

interface Props {
  headline: string;
  subheadline: string;
  primaryCta: Cta;
  secondaryCta?: Cta;
  showForm?: boolean;
  formId?: string;
  urgencyBadge?: string;
  compact?: boolean;
}

const {
  headline,
  subheadline,
  primaryCta,
  secondaryCta,
  showForm = true,
  formId = 'lead-form',
  urgencyBadge,
  compact = false,
} = Astro.props;

import LeadCaptureForm from './LeadCaptureForm.astro';
---

<section class={`hero ${compact ? 'hero--compact' : ''}`} aria-label="Hero section">
  <div
    class="hero__bg"
    role="img"
    aria-label="Plumber working on pipes in Vacaville CA"
  ></div>
  <div class="hero__overlay"></div>

  <div class="container hero__inner">
    <!-- Left: Copy -->
    <div class="hero__content">
      {urgencyBadge && (
        <span class="hero__badge">{urgencyBadge}</span>
      )}

      <h1 class="hero__headline">{headline}</h1>
      <p class="hero__subheadline">{subheadline}</p>

      <a
        href="tel:9166122126"
        class="hero__phone"
        aria-label="Call Vacaville Plumbing at (916) 612-2126"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hero__phone-icon">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        (916) 612-2126
      </a>

      <div class="hero__cta-group">
        <a href={primaryCta.href} class="hero__btn-primary">
          {primaryCta.label}
        </a>
        {secondaryCta && (
          <a href={secondaryCta.href} class="hero__btn-secondary">
            {secondaryCta.label}
          </a>
        )}
      </div>
    </div>

    <!-- Right: Lead Form -->
    {showForm && (
      <div class="hero__form">
        <LeadCaptureForm id={formId} />
      </div>
    )}
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero--compact {
    min-height: 60vh;
  }

  /* Background */
  .hero__bg {
    position: absolute;
    inset: 0;
    background-color: var(--color-primary);
    /* TODO: Replace with real photo: background-image: url('/images/hero-bg.jpg'); background-size: cover; background-position: center; */
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(30, 58, 95, 0.95), rgba(30, 58, 95, 0.7));
  }

  /* Inner layout */
  .hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    padding-top: var(--space-12);
    padding-bottom: var(--space-12);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero__inner {
      grid-template-columns: 3fr 2fr;
      gap: var(--space-8);
    }
  }

  /* Content */
  .hero__badge {
    display: inline-block;
    background: var(--color-accent);
    color: #ffffff;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 6px 16px;
    border-radius: 2px;
    margin-bottom: 20px;
  }

  .hero__headline {
    color: #ffffff;
    margin-bottom: var(--space-2);
  }

  .hero__subheadline {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.85);
    font-weight: 400;
    max-width: 480px;
    line-height: 1.65;
    margin-bottom: var(--space-3);
  }

  .hero__phone {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: #ffffff;
    text-decoration: none;
    margin-bottom: var(--space-3);
    transition: opacity 150ms ease;
  }

  .hero__phone:hover {
    opacity: 0.9;
    text-decoration: none;
    color: #ffffff;
  }

  .hero__phone-icon {
    color: var(--color-accent);
  }

  .hero__cta-group {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }

  .hero__btn-primary {
    display: inline-flex;
    align-items: center;
    background: var(--color-accent);
    color: #ffffff;
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    text-decoration: none;
    padding: 16px 36px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: background 150ms ease;
    white-space: nowrap;
  }

  .hero__btn-primary:hover {
    background: var(--color-accent-dark);
    text-decoration: none;
    color: #ffffff;
  }

  .hero__btn-secondary {
    display: inline-flex;
    align-items: center;
    background: transparent;
    color: #ffffff;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    padding: 14px 28px;
    border-radius: 4px;
    border: 2px solid rgba(255, 255, 255, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: background 150ms ease, color 150ms ease;
    white-space: nowrap;
  }

  .hero__btn-secondary:hover {
    background: #ffffff;
    color: var(--color-primary);
    text-decoration: none;
    border-color: #ffffff;
  }

  /* Form column */
  .hero__form {
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    border-radius: 6px;
  }
</style>
