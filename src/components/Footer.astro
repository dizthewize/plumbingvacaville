---
const services = [
  { label: 'Drain Cleaning & Unclogging', href: '/services/drain-cleaning' },
  { label: 'Water Heater Installation & Repair', href: '/services/water-heater' },
  { label: 'Leak Detection & Repair', href: '/services/leak-detection' },
  { label: 'Pipe Replacement & Repiping', href: '/services/repiping' },
  { label: 'Emergency Plumbing', href: '/services/emergency-plumbing' },
  { label: 'Bathroom & Kitchen Plumbing', href: '/services/bathroom-kitchen-plumbing' },
  { label: 'Toilet, Faucet & Fixture Installation', href: '/services/fixture-installation' },
  { label: 'Sewer Line Inspection & Repair', href: '/services/sewer-line' },
];

const serviceAreas = [
  { label: 'Vacaville', href: '/service-areas/vacaville' },
  { label: 'Fairfield', href: '/service-areas/fairfield' },
  { label: 'Dixon', href: '/service-areas/dixon' },
  { label: 'Napa', href: '/service-areas/napa' },
  { label: 'Vallejo', href: '/service-areas/vallejo' },
  { label: 'Woodland', href: '/service-areas/woodland' },
  { label: 'Davis', href: '/service-areas/davis' },
  { label: 'Winters', href: '/service-areas/winters' },
];

const companyLinks = [
  { label: 'About', href: '/about' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];

const currentYear = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <div class="container site-footer__grid">
    <!-- Column 1: Brand -->
    <div class="site-footer__brand">
      <a href="/" class="site-footer__logo" aria-label="Vacaville Plumbing — Home">
        Vacaville Plumbing
      </a>
      <p class="site-footer__tagline">
        Licensed plumbers serving Vacaville & surrounding areas.
      </p>
      <a href="tel:9166122126" class="site-footer__phone" aria-label="Call Vacaville Plumbing at (916) 612-2126">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="site-footer__phone-icon">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        (916) 612-2126
      </a>
      <!-- TODO: Add address when client provides it -->
      <!-- <address class="site-footer__address">
        123 Main St<br>
        Vacaville, CA 95688
      </address> -->
    </div>

    <!-- Column 2: Services -->
    <div class="site-footer__col">
      <h3 class="site-footer__col-heading">Services</h3>
      <ul class="site-footer__links">
        {services.map((link) => (
          <li><a href={link.href} class="site-footer__link">{link.label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Column 3: Service Areas -->
    <div class="site-footer__col">
      <h3 class="site-footer__col-heading">Service Areas</h3>
      <ul class="site-footer__links">
        {serviceAreas.map((area) => (
          <li><a href={area.href} class="site-footer__link">{area.label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Column 4: Company -->
    <div class="site-footer__col">
      <h3 class="site-footer__col-heading">Company</h3>
      <ul class="site-footer__links">
        {companyLinks.map((link) => (
          <li><a href={link.href} class="site-footer__link">{link.label}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="site-footer__bottom">
    <div class="container site-footer__bottom-inner">
      <span class="site-footer__copyright">
        © {currentYear} Vacaville Plumbing. CA Contractor License #C-36. All rights reserved.
      </span>
      <div class="site-footer__legal-links">
        <a href="/privacy" class="site-footer__legal-link">Privacy Policy</a>
        <a href="/terms" class="site-footer__legal-link">Terms</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-footer-bg);
    color: rgba(255, 255, 255, 0.75);
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    padding-top: 64px;
    padding-bottom: 40px;
  }

  @media (min-width: 768px) {
    .site-footer__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .site-footer__grid {
      grid-template-columns: 2fr 1fr 1fr 1fr;
    }
  }

  /* Brand Column */
  .site-footer__logo {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: #ffffff;
    text-decoration: none;
    display: block;
    margin-bottom: var(--space-2);
  }

  .site-footer__logo:hover {
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
  }

  .site-footer__tagline {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.6);
    font-style: italic;
    margin-bottom: var(--space-2);
    max-width: none;
  }

  .site-footer__phone {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 700;
    color: #ffffff;
    text-decoration: none;
    transition: opacity 150ms ease;
  }

  .site-footer__phone:hover {
    opacity: 0.9;
    text-decoration: none;
    color: #ffffff;
  }

  .site-footer__phone-icon {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  /* Columns */
  .site-footer__col-heading {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: var(--space-2);
    line-height: 1;
  }

  .site-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .site-footer__link {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    padding: 4px 0;
    display: block;
    transition: color 150ms ease;
  }

  .site-footer__link:hover {
    color: #ffffff;
    text-decoration: none;
  }

  /* Bottom Bar */
  .site-footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 24px 0;
  }

  .site-footer__bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  .site-footer__copyright {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.45);
  }

  .site-footer__legal-links {
    display: flex;
    gap: var(--space-2);
  }

  .site-footer__legal-link {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    transition: color 150ms ease;
  }

  .site-footer__legal-link:hover {
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
  }
</style>
