---
interface Signal {
  icon: string;
  label: string;
}

interface Props {
  variant?: 'dark' | 'light';
  signals?: Signal[];
}

const defaultSignals: Signal[] = [
  { icon: 'shield', label: 'Licensed & Insured (C-36)' },
  { icon: 'tag', label: 'Upfront Flat-Rate Pricing' },
  { icon: 'clock', label: 'Same-Day Service' },
  { icon: 'star', label: '5-Star Rated' },
  { icon: 'wrench', label: 'Parts & Labor Warranty' },
];

const { variant = 'dark', signals = defaultSignals } = Astro.props;

// SVG paths for icons
const iconPaths: Record<string, string> = {
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  tag: '<path d="M12 2H2v10l9.29 9.29a1 1 0 0 0 1.41 0l7.3-7.3a1 1 0 0 0 0-1.41L12 2z"/><circle cx="7" cy="7" r="1.5" fill="currentColor"/>',
  clock: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  star: '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>',
  wrench: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
};
---

<section class={`trust-bar trust-bar--${variant}`} aria-label="Why choose Vacaville Plumbing">
  <div class="container trust-bar__inner">
    {signals.map((signal) => (
      <div class="trust-bar__item">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="trust-bar__icon"
          aria-hidden="true"
          set:html={iconPaths[signal.icon] ?? iconPaths.wrench}
        />
        <span class="trust-bar__label">{signal.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .trust-bar {
    padding: var(--space-6) 0;
  }

  .trust-bar--dark {
    background: var(--color-primary);
  }

  .trust-bar--light {
    background: var(--color-neutral-50);
    border-top: 1px solid var(--color-neutral-200);
    border-bottom: 1px solid var(--color-neutral-200);
  }

  .trust-bar__inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 32px 48px;
  }

  @media (max-width: 767px) {
    .trust-bar__inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3);
      justify-items: center;
    }
  }

  .trust-bar__item {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .trust-bar__icon {
    flex-shrink: 0;
    color: var(--color-accent);
  }

  .trust-bar__label {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .trust-bar--dark .trust-bar__label {
    color: #ffffff;
  }

  .trust-bar--light .trust-bar__label {
    color: var(--color-primary);
  }
</style>
