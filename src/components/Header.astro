---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navLinks = [
  { label: 'Services', href: '/services' },
  { label: 'Service Areas', href: '/service-areas' },
  { label: 'About', href: '/about' },
  { label: 'Blog', href: '/blog' },
];
---

<header class="site-header" role="banner" id="site-header">
  <div class="container site-header__inner">
    <!-- Logo -->
    <a href="/" class="site-header__logo" aria-label="Vacaville Plumbing — Home">
      Vacaville Plumbing
    </a>

    <!-- Desktop Nav -->
    <nav class="site-header__nav" aria-label="Main navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`site-header__nav-link ${currentPath.startsWith(link.href) ? 'site-header__nav-link--active' : ''}`}
          aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Desktop Phone + CTA -->
    <div class="site-header__actions">
      <a href="tel:9166122126" class="site-header__phone" aria-label="Call Vacaville Plumbing at (916) 612-2126">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="site-header__phone-icon">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        (916) 612-2126
      </a>
      <a href="/contact" class="site-header__cta" aria-label="Get a free plumbing estimate">
        Free Estimate
      </a>
    </div>

    <!-- Mobile Hamburger -->
    <button
      class="site-header__hamburger"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      id="hamburger-btn"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="4" x2="20" y1="12" y2="12"/>
        <line x1="4" x2="20" y1="6" y2="6"/>
        <line x1="4" x2="20" y1="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav aria-label="Mobile navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="mobile-menu__link"
          aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
      <a href="tel:9166122126" class="mobile-menu__phone" aria-label="Call Vacaville Plumbing at (916) 612-2126">
        (916) 612-2126
      </a>
      <a href="/contact" class="mobile-menu__cta">
        Get a Free Estimate
      </a>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const hamburger = document.getElementById('hamburger-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  // Scroll shrink
  let lastScroll = 0;
  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;
    if (scrollY > 80) {
      header?.classList.add('site-header--scrolled');
    } else {
      header?.classList.remove('site-header--scrolled');
    }
    lastScroll = scrollY;
  }, { passive: true });

  // Mobile menu toggle
  hamburger?.addEventListener('click', () => {
    const isExpanded = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!isExpanded));
    mobileMenu?.setAttribute('aria-hidden', String(isExpanded));
    mobileMenu?.classList.toggle('mobile-menu--open');
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    background: var(--color-primary);
    height: 80px;
    transition: height 200ms ease, box-shadow 200ms ease;
  }

  .site-header--scrolled {
    height: 60px;
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.2);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    height: 100%;
    gap: var(--space-2);
  }

  /* Logo */
  .site-header__logo {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: #ffffff;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .site-header__logo:hover {
    color: rgba(255, 255, 255, 0.9);
  }

  /* Desktop Nav */
  .site-header__nav {
    display: none;
    align-items: center;
    gap: 0;
    margin-left: auto;
  }

  @media (min-width: 1024px) {
    .site-header__nav {
      display: flex;
    }
  }

  .site-header__nav-link {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    padding: 8px 16px;
    transition: color 150ms ease;
  }

  .site-header__nav-link:hover,
  .site-header__nav-link--active {
    color: #ffffff;
    text-decoration: underline;
  }

  /* Actions */
  .site-header__actions {
    display: none;
    align-items: center;
    gap: var(--space-2);
    margin-left: var(--space-2);
    flex-shrink: 0;
  }

  @media (min-width: 1024px) {
    .site-header__actions {
      display: flex;
    }
  }

  .site-header__phone {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: #ffffff;
    text-decoration: none;
    transition: opacity 150ms ease;
  }

  .site-header__phone:hover {
    opacity: 0.9;
    text-decoration: none;
  }

  .site-header__phone-icon {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .site-header__cta {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 700;
    color: #ffffff;
    text-decoration: none;
    background: var(--color-accent);
    padding: 10px 20px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    transition: background 150ms ease;
    white-space: nowrap;
  }

  .site-header__cta:hover {
    background: var(--color-accent-dark);
    text-decoration: none;
    color: #ffffff;
  }

  /* Hamburger */
  .site-header__hamburger {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-left: auto;
    background: none;
    border: none;
    color: #ffffff;
    cursor: pointer;
    padding: 8px;
    border-radius: 4px;
    transition: background 150ms ease;
  }

  .site-header__hamburger:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  @media (min-width: 1024px) {
    .site-header__hamburger {
      display: none;
    }
  }

  /* Mobile Menu */
  .mobile-menu {
    display: none;
    background: var(--color-primary-dark);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    z-index: var(--z-dropdown);
  }

  .mobile-menu--open {
    display: block;
  }

  .mobile-menu nav {
    display: flex;
    flex-direction: column;
  }

  .mobile-menu__link {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    padding: 16px var(--container-padding);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    min-height: 48px;
    display: flex;
    align-items: center;
    transition: color 150ms ease, background 150ms ease;
  }

  .mobile-menu__link:hover,
  .mobile-menu__link[aria-current="page"] {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.05);
    text-decoration: none;
  }

  .mobile-menu__phone {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: #ffffff;
    text-decoration: none;
    padding: 16px var(--container-padding);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    min-height: 48px;
    display: flex;
    align-items: center;
  }

  .mobile-menu__cta {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: #ffffff;
    text-decoration: none;
    background: var(--color-accent);
    padding: 16px var(--container-padding);
    display: flex;
    align-items: center;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    transition: background 150ms ease;
  }

  .mobile-menu__cta:hover {
    background: var(--color-accent-dark);
    text-decoration: none;
    color: #ffffff;
  }
</style>
