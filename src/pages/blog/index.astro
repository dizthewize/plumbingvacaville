---
import Layout from '../../layouts/Layout.astro';
import TrustSignalsBar from '../../components/TrustSignalsBar.astro';
---

<Layout
  title="Plumbing Tips & Advice | Vacaville Plumbing"
  description="Plumbing tips, maintenance advice, and emergency guides from the licensed plumbers at Vacaville Plumbing. Serving Vacaville, CA and surrounding areas."
>
  <section class="blog-hero" aria-label="Blog overview">
    <div class="container blog-hero__inner">
      <h1 class="blog-hero__headline">Plumbing Tips &amp; Advice</h1>
      <p class="blog-hero__sub">Guides, maintenance tips, and answers to common plumbing questions from the team at Vacaville Plumbing.</p>
    </div>
  </section>

  <TrustSignalsBar />

  <section class="blog-content" aria-labelledby="blog-posts-heading">
    <div class="container">
      <h2 id="blog-posts-heading" class="sr-only">Blog Posts</h2>
      <div class="blog-empty">
        <p class="blog-empty__headline">Posts Coming Soon</p>
        <p class="blog-empty__body">We're working on plumbing guides, maintenance tips, and local advice. Check back soon — or call us directly if you have a question.</p>
        <div class="blog-empty__ctas">
          <a href="tel:9166122126" class="blog-empty__cta-phone" aria-label="Call Vacaville Plumbing at (916) 612-2126">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call (916) 612-2126
          </a>
          <a href="/services" class="blog-empty__cta-services">Browse Our Services</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .blog-hero { background: var(--color-primary); padding: var(--space-12) 0; }
  .blog-hero__inner { display: flex; flex-direction: column; gap: var(--space-2); max-width: 800px; }
  .blog-hero__headline { color: #fff; }
  .blog-hero__sub { font-family: var(--font-display); font-size: 1.125rem; font-weight: 500; color: rgba(255,255,255,.85); max-width: 600px; }
  .blog-content { padding: var(--space-12) 0; background: var(--color-neutral-50); min-height: 320px; }
  .blog-empty { max-width: 560px; text-align: center; margin: var(--space-8) auto; padding: var(--space-8) var(--space-4); background: #fff; border: 1px solid var(--color-neutral-200); border-radius: 8px; }
  .blog-empty__headline { font-family: var(--font-display); font-size: 1.375rem; font-weight: 700; color: var(--color-primary); margin-bottom: var(--space-2); }
  .blog-empty__body { font-size: 1rem; color: var(--color-text-muted); line-height: 1.65; margin-bottom: var(--space-4); }
  .blog-empty__ctas { display: flex; flex-wrap: wrap; gap: var(--space-2); justify-content: center; }
  .blog-empty__cta-phone { display: inline-flex; align-items: center; gap: 8px; background: var(--color-accent); color: #fff; font-family: var(--font-display); font-size: .9375rem; font-weight: 700; text-decoration: none; padding: 12px 24px; border-radius: 4px; text-transform: uppercase; letter-spacing: .04em; transition: background 150ms ease; }
  .blog-empty__cta-phone:hover { background: var(--color-accent-dark); text-decoration: none; color: #fff; }
  .blog-empty__cta-services { display: inline-flex; align-items: center; background: transparent; color: var(--color-primary); font-family: var(--font-display); font-size: .9375rem; font-weight: 700; text-decoration: none; padding: 12px 24px; border-radius: 4px; border: 2px solid var(--color-primary); text-transform: uppercase; letter-spacing: .04em; transition: background 150ms ease, color 150ms ease; }
  .blog-empty__cta-services:hover { background: var(--color-primary); color: #fff; text-decoration: none; }
</style>
