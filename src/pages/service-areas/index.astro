---
import Layout from '../../layouts/Layout.astro';
import TrustSignalsBar from '../../components/TrustSignalsBar.astro';
import LeadCaptureForm from '../../components/LeadCaptureForm.astro';
---

<Layout
  title="Plumber Serving Vacaville & Surrounding Areas | Vacaville Plumbing"
  description="Vacaville Plumbing serves Vacaville, Fairfield, Dixon, Napa, Vallejo, Woodland, Davis, Winters & more. Licensed & insured. Call (916) 612-2126."
>
  <section class="page-hero" aria-label="Service areas overview">
    <div class="container page-hero__inner">
      <h1 class="page-hero__headline">Plumber Serving Vacaville &amp; Surrounding Areas</h1>
      <p class="page-hero__sub">Same-day plumbing service within 30 miles of Vacaville, CA.</p>
      <p class="page-hero__body">
        Vacaville Plumbing serves homeowners and businesses throughout Vacaville and the surrounding communities.
        Wherever you are in our service area, you get the same licensed plumber, the same upfront pricing, and the
        same fast response time.
      </p>
      <div class="page-hero__ctas">
        <a href="tel:9166122126" class="page-hero__cta-primary" aria-label="Call Vacaville Plumbing at (916) 612-2126">Call (916) 612-2126 for Service in Your Area</a>
        <a href="#lead-form" class="page-hero__cta-secondary">Same-Day Appointments Available</a>
      </div>
    </div>
  </section>

  <TrustSignalsBar />

  <section class="cities-section" aria-labelledby="cities-heading">
    <div class="container">
      <h2 id="cities-heading" class="cities-section__headline">Cities We Serve</h2>
      <p class="cities-section__intro">
        We provide the same licensed service, upfront pricing, and fast response to every city in our coverage area.
      </p>
      <ul class="cities-grid" role="list">
        <li><a href="/service-areas/vacaville" class="city-card">
          <span class="city-card__name">Vacaville</span>
          <span class="city-card__desc">Our home base — same-day and emergency service always available.</span>
        </a></li>
        <li><a href="/service-areas/fairfield" class="city-card">
          <span class="city-card__name">Fairfield</span>
          <span class="city-card__desc">Licensed plumber serving Fairfield with fast response and upfront pricing.</span>
        </a></li>
        <li><a href="/service-areas/dixon" class="city-card">
          <span class="city-card__name">Dixon</span>
          <span class="city-card__desc">Drain cleaning, water heater service, and more in Dixon, CA.</span>
        </a></li>
        <li><a href="/service-areas/napa" class="city-card">
          <span class="city-card__name">Napa</span>
          <span class="city-card__desc">Same-day plumbing service available in Napa and surrounding areas.</span>
        </a></li>
        <li><a href="/service-areas/vallejo" class="city-card">
          <span class="city-card__name">Vallejo</span>
          <span class="city-card__desc">Emergency and scheduled plumbing service in Vallejo, CA.</span>
        </a></li>
        <li><a href="/service-areas/woodland" class="city-card">
          <span class="city-card__name">Woodland</span>
          <span class="city-card__desc">Licensed plumbing repairs and installs in Woodland, CA.</span>
        </a></li>
        <li><a href="/service-areas/davis" class="city-card">
          <span class="city-card__name">Davis</span>
          <span class="city-card__desc">Fast, reliable plumbing service for Davis homeowners and businesses.</span>
        </a></li>
        <li><a href="/service-areas/winters" class="city-card">
          <span class="city-card__name">Winters</span>
          <span class="city-card__desc">Serving Winters, CA with the same upfront pricing and fast response.</span>
        </a></li>
      </ul>
    </div>
  </section>

  <section class="service-area-cta" aria-labelledby="area-cta-heading">
    <div class="container service-area-cta__inner">
      <div class="service-area-cta__copy">
        <h2 id="area-cta-heading">Ready to Get Your Plumbing Fixed?</h2>
        <p>Same-day appointments available. Emergency service 24/7. Free estimates on most jobs.</p>
        <a href="tel:9166122126" class="service-area-cta__phone" aria-label="Call Vacaville Plumbing at (916) 612-2126">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          (916) 612-2126
        </a>
      </div>
      <div class="service-area-cta__form">
        <LeadCaptureForm id="lead-form" formTitle="Request My Free Estimate" />
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero { background: var(--color-primary); padding: var(--space-12) 0; }
  .page-hero__inner { display: flex; flex-direction: column; gap: var(--space-2); max-width: 800px; }
  .page-hero__headline { color: #fff; }
  .page-hero__sub { font-family: var(--font-display); font-size: 1.25rem; font-weight: 600; color: rgba(255,255,255,.9); }
  .page-hero__body { font-size: 1rem; color: rgba(255,255,255,.8); line-height: 1.65; max-width: 680px; }
  .page-hero__ctas { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-top: var(--space-2); }
  .page-hero__cta-primary { display: inline-flex; align-items: center; background: var(--color-accent); color: #fff; font-family: var(--font-display); font-size: 1.0625rem; font-weight: 700; text-decoration: none; padding: 14px 32px; border-radius: 4px; text-transform: uppercase; letter-spacing: .04em; transition: background 150ms ease; }
  .page-hero__cta-primary:hover { background: var(--color-accent-dark); text-decoration: none; color: #fff; }
  .page-hero__cta-secondary { display: inline-flex; align-items: center; background: transparent; color: #fff; font-family: var(--font-display); font-size: .9375rem; font-weight: 700; text-decoration: none; padding: 12px 24px; border-radius: 4px; border: 2px solid rgba(255,255,255,.6); text-transform: uppercase; letter-spacing: .04em; transition: background 150ms ease, color 150ms ease; }
  .page-hero__cta-secondary:hover { background: #fff; color: var(--color-primary); text-decoration: none; }
  .cities-section { padding: var(--space-12) 0; background: #fff; }
  .cities-section__headline { color: var(--color-primary); margin-bottom: var(--space-2); }
  .cities-section__intro { font-size: 1rem; color: var(--color-text-muted); line-height: 1.65; margin-bottom: var(--space-6); max-width: 640px; }
  .cities-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: var(--space-3); list-style: none; padding: 0; margin: 0; }
  .city-card { display: flex; flex-direction: column; gap: 6px; padding: var(--space-3); background: var(--color-neutral-50); border: 1px solid var(--color-neutral-200); border-radius: 6px; text-decoration: none; transition: border-color 150ms ease, box-shadow 150ms ease; }
  .city-card:hover { border-color: var(--color-accent); box-shadow: 0 4px 16px rgba(0,0,0,.07); text-decoration: none; }
  .city-card__name { font-family: var(--font-display); font-size: 1.125rem; font-weight: 700; color: var(--color-primary); }
  .city-card__desc { font-size: .9rem; color: var(--color-text-muted); line-height: 1.5; }
  .service-area-cta { background: var(--color-neutral-50); padding: var(--space-12) 0; border-top: 1px solid var(--color-neutral-200); }
  .service-area-cta__inner { display: grid; grid-template-columns: 1fr; gap: var(--space-6); align-items: center; }
  @media (min-width: 1024px) { .service-area-cta__inner { grid-template-columns: 1fr 1fr; } }
  .service-area-cta__copy h2 { color: var(--color-primary); margin-bottom: var(--space-2); }
  .service-area-cta__copy p { font-size: 1rem; color: var(--color-text); line-height: 1.65; margin-bottom: var(--space-3); }
  .service-area-cta__phone { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-display); font-size: 1.5rem; font-weight: 700; color: var(--color-primary); text-decoration: none; transition: color 150ms ease; }
  .service-area-cta__phone:hover { color: var(--color-accent); text-decoration: none; }
  .service-area-cta__phone svg { color: var(--color-accent); }
  .service-area-cta__form { box-shadow: 0 4px 24px rgba(0,0,0,.08); border-radius: 6px; border: 1px solid var(--color-neutral-200); }
</style>
