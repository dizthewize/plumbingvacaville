---
import Layout from '../../layouts/Layout.astro';
import TrustSignalsBar from '../../components/TrustSignalsBar.astro';
import LeadCaptureForm from '../../components/LeadCaptureForm.astro';

const city = 'Dixon';
---

<Layout
  title={`Plumber in ${city}, CA — Same-Day Service | Vacaville Plumbing`}
  description={`Looking for a plumber in ${city}, CA? Vacaville Plumbing offers same-day service, upfront pricing & licensed techs. Call (916) 612-2126 today.`}
>
  <section class="city-hero" aria-label={`Plumbing service in ${city}`}>
    <div class="container city-hero__inner">
      <h1 class="city-hero__headline">Plumber in {city}, CA — Same-Day Service Available</h1>
      <p class="city-hero__sub">Vacaville Plumbing serves {city} with licensed plumbers, upfront pricing, and fast response.</p>
      <p class="city-hero__body">
        Need a plumber in {city}? Vacaville Plumbing is your local plumbing company for drain cleaning, water heater
        repair, leak detection, emergency service, and more. We serve {city} residents with the same upfront pricing
        and same-day availability we're known for in Vacaville. Licensed, insured, and ready when you call.
      </p>
      <div class="city-hero__ctas">
        <a href="tel:9166122126" class="city-hero__cta-primary" aria-label={`Call Vacaville Plumbing for service in ${city}`}>Get Service in {city} — Call (916) 612-2126</a>
        <a href="#lead-form" class="city-hero__cta-secondary">Get a Free Estimate</a>
      </div>
    </div>
  </section>

  <TrustSignalsBar />

  <section class="city-services" aria-labelledby="city-services-heading">
    <div class="container">
      <h2 id="city-services-heading">Our Plumbing Services</h2>
      <p class="city-services__intro">From drain cleaning to full sewer line repair, we handle it all — with upfront pricing on every job.</p>
      <ul class="service-links" role="list">
        <li><a href="/services/drain-cleaning">Drain Cleaning &amp; Unclogging</a></li>
        <li><a href="/services/water-heater">Water Heater Repair &amp; Installation</a></li>
        <li><a href="/services/leak-detection">Leak Detection &amp; Repair</a></li>
        <li><a href="/services/repiping">Pipe Replacement &amp; Repiping</a></li>
        <li><a href="/services/emergency-plumbing">Emergency Plumbing</a></li>
        <li><a href="/services/bathroom-kitchen-plumbing">Bathroom &amp; Kitchen Plumbing</a></li>
        <li><a href="/services/fixture-installation">Toilet, Faucet &amp; Fixture Installation</a></li>
        <li><a href="/services/sewer-line">Sewer Line Inspection &amp; Repair</a></li>
      </ul>
      <p class="city-services__cta"><a href="/services">View All Plumbing Services →</a></p>
    </div>
  </section>

  <section class="city-form" aria-labelledby="city-form-heading">
    <div class="container city-form__inner">
      <div class="city-form__copy">
        <h2 id="city-form-heading">Ready to Get Your Plumbing Fixed?</h2>
        <p>Same-day appointments available. Emergency service 24/7. Free estimates on most jobs.</p>
        <a href="tel:9166122126" class="city-form__phone" aria-label="Call Vacaville Plumbing at (916) 612-2126">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          (916) 612-2126
        </a>
        <p class="city-form__link-back"><a href="/service-areas">← All Service Areas</a></p>
      </div>
      <div class="city-form__form">
        <LeadCaptureForm id="lead-form" formTitle="Request My Free Estimate" />
      </div>
    </div>
  </section>
</Layout>

<style>
  .city-hero { background: var(--color-primary); padding: var(--space-12) 0; }
  .city-hero__inner { display: flex; flex-direction: column; gap: var(--space-2); max-width: 800px; }
  .city-hero__headline { color: #fff; }
  .city-hero__sub { font-family: var(--font-display); font-size: 1.25rem; font-weight: 600; color: rgba(255,255,255,.9); }
  .city-hero__body { font-size: 1rem; color: rgba(255,255,255,.8); line-height: 1.65; max-width: 680px; }
  .city-hero__ctas { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-top: var(--space-2); }
  .city-hero__cta-primary { display: inline-flex; align-items: center; background: var(--color-accent); color: #fff; font-family: var(--font-display); font-size: 1.0625rem; font-weight: 700; text-decoration: none; padding: 14px 32px; border-radius: 4px; text-transform: uppercase; letter-spacing: .04em; transition: background 150ms ease; }
  .city-hero__cta-primary:hover { background: var(--color-accent-dark); text-decoration: none; color: #fff; }
  .city-hero__cta-secondary { display: inline-flex; align-items: center; background: transparent; color: #fff; font-family: var(--font-display); font-size: .9375rem; font-weight: 700; text-decoration: none; padding: 12px 24px; border-radius: 4px; border: 2px solid rgba(255,255,255,.6); text-transform: uppercase; letter-spacing: .04em; transition: background 150ms ease, color 150ms ease; }
  .city-hero__cta-secondary:hover { background: #fff; color: var(--color-primary); text-decoration: none; }
  .city-services { padding: var(--space-12) 0; background: #fff; }
  .city-services h2 { color: var(--color-primary); margin-bottom: var(--space-2); }
  .city-services__intro { font-size: 1rem; color: var(--color-text-muted); margin-bottom: var(--space-4); max-width: 600px; }
  .service-links { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: var(--space-2); list-style: none; padding: 0; margin: 0 0 var(--space-4); }
  .service-links li a { display: block; padding: 12px 16px; background: var(--color-neutral-50); border: 1px solid var(--color-neutral-200); border-radius: 4px; font-family: var(--font-display); font-weight: 600; color: var(--color-primary); text-decoration: none; transition: border-color 150ms ease; }
  .service-links li a:hover { border-color: var(--color-accent); text-decoration: none; color: var(--color-accent); }
  .city-services__cta a { font-family: var(--font-display); font-weight: 600; color: var(--color-accent); }
  .city-form { background: var(--color-neutral-50); padding: var(--space-12) 0; border-top: 1px solid var(--color-neutral-200); }
  .city-form__inner { display: grid; grid-template-columns: 1fr; gap: var(--space-6); align-items: center; }
  @media (min-width: 1024px) { .city-form__inner { grid-template-columns: 1fr 1fr; } }
  .city-form__copy h2 { color: var(--color-primary); margin-bottom: var(--space-2); }
  .city-form__copy p { font-size: 1rem; color: var(--color-text); line-height: 1.65; margin-bottom: var(--space-2); }
  .city-form__phone { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-display); font-size: 1.5rem; font-weight: 700; color: var(--color-primary); text-decoration: none; margin-bottom: var(--space-2); transition: color 150ms ease; }
  .city-form__phone:hover { color: var(--color-accent); text-decoration: none; }
  .city-form__phone svg { color: var(--color-accent); }
  .city-form__link-back a { color: var(--color-primary-light); text-decoration: underline; font-size: .9rem; }
  .city-form__form { box-shadow: 0 4px 24px rgba(0,0,0,.08); border-radius: 6px; border: 1px solid var(--color-neutral-200); }
</style>
