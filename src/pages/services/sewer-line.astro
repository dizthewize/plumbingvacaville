---
import Layout from '../../layouts/Layout.astro';
import TrustSignalsBar from '../../components/TrustSignalsBar.astro';
import OfferSection from '../../components/OfferSection.astro';
import LeadCaptureForm from '../../components/LeadCaptureForm.astro';
---

<Layout
  title="Sewer Line Inspection & Repair Vacaville, CA | Vacaville Plumbing"
  description="Sewer line inspection & repair in Vacaville, CA. Camera inspection, trenchless options. Licensed plumber. Call (916) 612-2126 for a free estimate."
>
  <section class="service-hero" aria-label="Sewer line service">
    <div class="container service-hero__inner">
      <span class="service-hero__badge">Don't Ignore Sewer Warning Signs</span>
      <h1 class="service-hero__headline">Sewer Line Inspection &amp; Repair in Vacaville, CA</h1>
      <p class="service-hero__sub">Camera inspection, root removal, trenchless repair — we find it and fix it.</p>
      <p class="service-hero__body">
        Sewer problems show up in ways that are hard to ignore: multiple drains backing up at once, sewage smell in
        your yard, or soggy patches in the lawn. Vacaville Plumbing performs video camera inspections to see exactly
        what's happening underground — then gives you a clear repair plan and price before any digging starts.
      </p>
      <p class="service-hero__supporting">
        We offer trenchless repair options on qualifying lines to minimize yard disruption. Tree root intrusion, pipe
        collapse, and offset joints are the most common issues we find — all fixable with the right approach.
      </p>
      <div class="service-hero__ctas">
        <a href="#lead-form" class="service-hero__cta-primary">Schedule a Sewer Inspection</a>
        <a href="tel:9166122126" class="service-hero__cta-secondary" aria-label="Call Vacaville Plumbing at (916) 612-2126">Call (916) 612-2126 — Don't Ignore Sewer Warning Signs</a>
      </div>
    </div>
  </section>

  <TrustSignalsBar />

  <OfferSection
    badge="CLEAR PLAN BEFORE ANY DIGGING"
    headline="Get a Free Estimate — No Obligation, No Surprises"
    body="Call us or fill out the form and we'll get back to you same day. Upfront pricing before any work starts."
    primaryCta={{ label: 'Request My Free Estimate', href: '#lead-form' }}
    secondaryCta={{ label: 'Call (916) 612-2126', href: 'tel:9166122126' }}
  />

  <section class="service-form" aria-labelledby="service-form-heading">
    <div class="container service-form__inner">
      <div class="service-form__copy">
        <h2 id="service-form-heading">Ready to Get Your Plumbing Fixed?</h2>
        <p>Same-day appointments available. Emergency service 24/7. Free estimates on most jobs.</p>
        <a href="tel:9166122126" class="service-form__phone" aria-label="Call Vacaville Plumbing at (916) 612-2126">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          (916) 612-2126
        </a>
        <p class="service-form__link-back"><a href="/services">← Back to All Services</a></p>
      </div>
      <div class="service-form__form">
        <LeadCaptureForm id="lead-form" formTitle="Schedule a Sewer Inspection" />
      </div>
    </div>
  </section>
</Layout>

<style>
  .service-hero { background: var(--color-primary); padding: var(--space-12) 0; }
  .service-hero__inner { display: flex; flex-direction: column; gap: var(--space-2); max-width: 800px; }
  .service-hero__badge { display: inline-block; background: var(--color-accent); color: #fff; font-family: var(--font-display); font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; padding: 6px 16px; border-radius: 2px; margin-bottom: 12px; }
  .service-hero__headline { color: #ffffff; }
  .service-hero__sub { font-family: var(--font-display); font-size: 1.25rem; font-weight: 600; color: rgba(255,255,255,.9); max-width: none; }
  .service-hero__body, .service-hero__supporting { font-family: var(--font-body); font-size: 1rem; color: rgba(255,255,255,.8); line-height: 1.65; max-width: 680px; }
  .service-hero__ctas { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-top: var(--space-2); }
  .service-hero__cta-primary { display: inline-flex; align-items: center; background: var(--color-accent); color: #fff; font-family: var(--font-display); font-size: 1.0625rem; font-weight: 700; text-decoration: none; padding: 14px 32px; border-radius: 4px; text-transform: uppercase; letter-spacing: .04em; transition: background 150ms ease; }
  .service-hero__cta-primary:hover { background: var(--color-accent-dark); text-decoration: none; color: #fff; }
  .service-hero__cta-secondary { display: inline-flex; align-items: center; background: transparent; color: #fff; font-family: var(--font-display); font-size: .9375rem; font-weight: 700; text-decoration: none; padding: 12px 24px; border-radius: 4px; border: 2px solid rgba(255,255,255,.6); text-transform: uppercase; letter-spacing: .04em; transition: background 150ms ease, color 150ms ease; }
  .service-hero__cta-secondary:hover { background: #fff; color: var(--color-primary); text-decoration: none; }
  .service-form { background: var(--color-neutral-50); padding: var(--space-12) 0; border-top: 1px solid var(--color-neutral-200); }
  .service-form__inner { display: grid; grid-template-columns: 1fr; gap: var(--space-6); align-items: center; }
  @media (min-width: 1024px) { .service-form__inner { grid-template-columns: 1fr 1fr; } }
  .service-form__copy h2 { color: var(--color-primary); margin-bottom: var(--space-2); }
  .service-form__copy p { font-size: 1rem; color: var(--color-text); line-height: 1.65; margin-bottom: var(--space-2); }
  .service-form__phone { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-display); font-size: 1.5rem; font-weight: 700; color: var(--color-primary); text-decoration: none; margin-bottom: var(--space-2); transition: color 150ms ease; }
  .service-form__phone:hover { color: var(--color-accent); text-decoration: none; }
  .service-form__phone svg { color: var(--color-accent); }
  .service-form__link-back a { color: var(--color-primary-light); text-decoration: underline; font-size: .9rem; }
  .service-form__form { box-shadow: 0 4px 24px rgba(0,0,0,.08); border-radius: 6px; border: 1px solid var(--color-neutral-200); }
</style>
