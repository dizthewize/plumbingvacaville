---
import Layout from '../layouts/Layout.astro';
import TrustSignalsBar from '../components/TrustSignalsBar.astro';
import LeadCaptureForm from '../components/LeadCaptureForm.astro';
---

<Layout
  title="Contact Vacaville Plumbing — Get a Free Estimate in Vacaville, CA"
  description="Contact Vacaville Plumbing for a free estimate. Serving Vacaville, CA and surrounding areas. Call (916) 612-2126 or submit our quick online form."
>
  <section class="contact-hero" aria-label="Contact Vacaville Plumbing">
    <div class="container contact-hero__inner">
      <h1 class="contact-hero__headline">Get a Free Estimate from Vacaville Plumbing</h1>
      <p class="contact-hero__sub">Call us, text us, or fill out the form below — we respond fast.</p>
      <p class="contact-hero__body">
        Ready to get your plumbing problem solved? Call <a href="tel:9166122126">(916) 612-2126</a> for the fastest
        response — especially for emergencies. Prefer to submit a request? Fill out the form and we'll follow up same
        day during business hours.
      </p>
    </div>
  </section>

  <TrustSignalsBar />

  <section class="contact-main" aria-labelledby="contact-form-heading">
    <div class="container contact-main__inner">
      <div class="contact-info">
        <h2 id="contact-form-heading">Contact Us</h2>
        <p class="contact-info__intro">Tell us what's going on. We'll get back to you quickly with a free estimate and our earliest available time.</p>

        <div class="contact-info__block">
          <h3 class="contact-info__label">Phone</h3>
          <a href="tel:9166122126" class="contact-info__phone" aria-label="Call Vacaville Plumbing at (916) 612-2126">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            (916) 612-2126
          </a>
          <p class="contact-info__note">For emergencies, call now — we answer 24/7.</p>
        </div>

        <div class="contact-info__block">
          <h3 class="contact-info__label">Service Area</h3>
          <p>Vacaville, Fairfield, Dixon, Napa, Vallejo, Woodland, Davis, Winters, and surrounding communities within 30 miles.</p>
        </div>

        <div class="contact-info__block">
          <h3 class="contact-info__label">Hours</h3>
          <p>Emergency line: 24/7<br>Office hours: Monday–Friday, 8am–6pm<br>Saturday: By appointment</p>
        </div>
      </div>

      <div class="contact-form-wrap">
        <LeadCaptureForm id="lead-form" formTitle="Send My Request" submitLabel="Send My Request" />
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-hero { background: var(--color-primary); padding: var(--space-12) 0; }
  .contact-hero__inner { display: flex; flex-direction: column; gap: var(--space-2); max-width: 800px; }
  .contact-hero__headline { color: #fff; }
  .contact-hero__sub { font-family: var(--font-display); font-size: 1.25rem; font-weight: 600; color: rgba(255,255,255,.9); }
  .contact-hero__body { font-size: 1rem; color: rgba(255,255,255,.8); line-height: 1.65; max-width: 680px; }
  .contact-hero__body a { color: rgba(255,255,255,.95); text-decoration: underline; }
  .contact-main { padding: var(--space-12) 0; background: var(--color-neutral-50); }
  .contact-main__inner { display: grid; grid-template-columns: 1fr; gap: var(--space-8); align-items: start; }
  @media (min-width: 1024px) { .contact-main__inner { grid-template-columns: 1fr 1fr; } }
  .contact-info h2 { color: var(--color-primary); margin-bottom: var(--space-2); }
  .contact-info__intro { font-size: 1rem; color: var(--color-text-muted); line-height: 1.65; margin-bottom: var(--space-4); }
  .contact-info__block { margin-bottom: var(--space-4); }
  .contact-info__label { font-family: var(--font-display); font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--color-accent); margin-bottom: 8px; }
  .contact-info__phone { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-display); font-size: 1.75rem; font-weight: 700; color: var(--color-primary); text-decoration: none; margin-bottom: 8px; transition: color 150ms ease; }
  .contact-info__phone:hover { color: var(--color-accent); text-decoration: none; }
  .contact-info__phone svg { color: var(--color-accent); }
  .contact-info__note { font-size: .875rem; color: var(--color-text-muted); }
  .contact-info p { font-size: .9375rem; color: var(--color-text); line-height: 1.65; }
  .contact-form-wrap { box-shadow: 0 4px 24px rgba(0,0,0,.08); border-radius: 6px; border: 1px solid var(--color-neutral-200); }
</style>
