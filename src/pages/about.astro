---
import Layout from '../layouts/Layout.astro';
import TrustSignalsBar from '../components/TrustSignalsBar.astro';
import LeadCaptureForm from '../components/LeadCaptureForm.astro';
---

<Layout
  title="About Vacaville Plumbing — Licensed Plumbers in Vacaville, CA"
  description="Vacaville Plumbing is a licensed, insured plumbing company serving Vacaville, CA and surrounding areas. Upfront pricing, same-day service available."
>
  <section class="about-hero" aria-label="About Vacaville Plumbing">
    <div class="container about-hero__inner">
      <h1 class="about-hero__headline">Vacaville Plumbing — Licensed, Local, Honest</h1>
      <p class="about-hero__sub">We built this business on one idea: tell people what it costs before we start, then do the job right.</p>
      <p class="about-hero__body">
        Vacaville Plumbing is a locally owned plumbing company serving Vacaville and the surrounding communities. We
        started because we kept hearing the same frustration: plumbers who show up late, quote low, and bill high. We
        do it differently — upfront flat-rate pricing, on-time arrivals, and work that's backed by a warranty.
      </p>
      <div class="about-hero__ctas">
        <a href="/services" class="about-hero__cta-primary">See Our Services</a>
        <a href="tel:9166122126" class="about-hero__cta-secondary" aria-label="Call Vacaville Plumbing at (916) 612-2126">Call (916) 612-2126</a>
      </div>
    </div>
  </section>

  <TrustSignalsBar />

  <section class="values-section" aria-labelledby="values-heading">
    <div class="container">
      <h2 id="values-heading" class="values-section__headline">How We Do Business</h2>
      <ul class="values-grid" role="list">
        <li class="value-card">
          <h3 class="value-card__title">No hidden fees.</h3>
          <p class="value-card__body">You get a firm price before any work begins.</p>
        </li>
        <li class="value-card">
          <h3 class="value-card__title">We show up.</h3>
          <p class="value-card__body">On-time arrivals and same-day slots for most calls.</p>
        </li>
        <li class="value-card">
          <h3 class="value-card__title">We stand behind our work.</h3>
          <p class="value-card__body">Every repair is covered by our parts and labor warranty.</p>
        </li>
        <li class="value-card">
          <h3 class="value-card__title">Local.</h3>
          <p class="value-card__body">We live and work in this area — our reputation here matters to us.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="about-cta" aria-labelledby="about-cta-heading">
    <div class="container about-cta__inner">
      <div class="about-cta__copy">
        <h2 id="about-cta-heading">Ready to Get Your Plumbing Fixed?</h2>
        <p>Same-day appointments available. Emergency service 24/7. Free estimates on most jobs.</p>
        <a href="tel:9166122126" class="about-cta__phone" aria-label="Call Vacaville Plumbing at (916) 612-2126">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          (916) 612-2126
        </a>
      </div>
      <div class="about-cta__form">
        <LeadCaptureForm id="lead-form" formTitle="Request My Free Estimate" />
      </div>
    </div>
  </section>
</Layout>

<style>
  .about-hero { background: var(--color-primary); padding: var(--space-12) 0; }
  .about-hero__inner { display: flex; flex-direction: column; gap: var(--space-2); max-width: 800px; }
  .about-hero__headline { color: #fff; }
  .about-hero__sub { font-family: var(--font-display); font-size: 1.25rem; font-weight: 600; color: rgba(255,255,255,.9); }
  .about-hero__body { font-size: 1rem; color: rgba(255,255,255,.8); line-height: 1.65; max-width: 680px; }
  .about-hero__ctas { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-top: var(--space-2); }
  .about-hero__cta-primary { display: inline-flex; align-items: center; background: var(--color-accent); color: #fff; font-family: var(--font-display); font-size: 1.0625rem; font-weight: 700; text-decoration: none; padding: 14px 32px; border-radius: 4px; text-transform: uppercase; letter-spacing: .04em; transition: background 150ms ease; }
  .about-hero__cta-primary:hover { background: var(--color-accent-dark); text-decoration: none; color: #fff; }
  .about-hero__cta-secondary { display: inline-flex; align-items: center; background: transparent; color: #fff; font-family: var(--font-display); font-size: .9375rem; font-weight: 700; text-decoration: none; padding: 12px 24px; border-radius: 4px; border: 2px solid rgba(255,255,255,.6); text-transform: uppercase; letter-spacing: .04em; transition: background 150ms ease, color 150ms ease; }
  .about-hero__cta-secondary:hover { background: #fff; color: var(--color-primary); text-decoration: none; }
  .values-section { padding: var(--space-12) 0; background: #fff; }
  .values-section__headline { color: var(--color-primary); margin-bottom: var(--space-6); }
  .values-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: var(--space-3); list-style: none; padding: 0; margin: 0; }
  .value-card { padding: var(--space-3); background: var(--color-neutral-50); border: 1px solid var(--color-neutral-200); border-top: 3px solid var(--color-accent); border-radius: 6px; }
  .value-card__title { font-family: var(--font-display); font-size: 1.125rem; font-weight: 700; color: var(--color-primary); margin-bottom: 8px; }
  .value-card__body { font-size: .9375rem; color: var(--color-text); line-height: 1.6; }
  .about-cta { background: var(--color-neutral-50); padding: var(--space-12) 0; border-top: 1px solid var(--color-neutral-200); }
  .about-cta__inner { display: grid; grid-template-columns: 1fr; gap: var(--space-6); align-items: center; }
  @media (min-width: 1024px) { .about-cta__inner { grid-template-columns: 1fr 1fr; } }
  .about-cta__copy h2 { color: var(--color-primary); margin-bottom: var(--space-2); }
  .about-cta__copy p { font-size: 1rem; color: var(--color-text); line-height: 1.65; margin-bottom: var(--space-3); }
  .about-cta__phone { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-display); font-size: 1.5rem; font-weight: 700; color: var(--color-primary); text-decoration: none; transition: color 150ms ease; }
  .about-cta__phone:hover { color: var(--color-accent); text-decoration: none; }
  .about-cta__phone svg { color: var(--color-accent); }
  .about-cta__form { box-shadow: 0 4px 24px rgba(0,0,0,.08); border-radius: 6px; border: 1px solid var(--color-neutral-200); }
</style>
